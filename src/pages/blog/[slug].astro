---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = {
  'gorilla-permit-increase-2025': { title: 'Gorilla trekking permits: what to know', text: 'Permit pricing and availability should be checked directly with official sources before booking. Build flexibility into your dates, particularly in peak seasons.' },
  'kigali-safest-city-2025': { title: 'Planning a safe, smooth Kigali stay', text: 'Kigali is a welcoming place to begin a Rwanda journey. As anywhere, use normal travel awareness, arrange trusted transport, and keep documents secure.' },
  'new-flights-to-rwanda': { title: 'Flying to Rwanda: planning your arrival', text: 'Compare routes to Kigali International Airport and leave enough connection time. Confirm airline schedules and entry requirements before purchasing tickets.' },
  'best-time-to-visit': { title: 'The best time to visit Rwanda', text: 'Rwanda rewards travellers year-round. Match your season to activities: drier months suit trekking, while greener periods can bring quieter stays and dramatic scenery.' }
};
export function getStaticPaths() { return ['gorilla-permit-increase-2025', 'kigali-safest-city-2025', 'new-flights-to-rwanda', 'best-time-to-visit'].map(slug => ({ params: { slug } })); }
const post = posts[Astro.params.slug as keyof typeof posts];
---
<Layout title={`${post.title} - Rwanda Visa`}>
  <Header />
  <article class="s support-hero"><div class="s-narrow"><span class="s-label">Rwanda insights</span><h1 class="s-heading">{post.title}</h1><p class="s-body">{post.text}</p><a class="support-button" href="/itinerary">Plan your journey →</a></div></article>
  <Footer />
</Layout>
