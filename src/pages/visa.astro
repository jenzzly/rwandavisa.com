---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'visa');
const p = page!.data;
---

<Layout title={p.title}>
  <Header />

  <!-- Hero -->
  <section id="visa-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">{p.label}</span>
        <h1 class="s-heading">{p.heading}</h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">{p.subheading}</p>
      </div>
    </div>
  </section>

  <!-- Ad Top -->
  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Visa Types -->
  <section class="s">
    <div class="dest-intro" style="padding: 0 0 3rem 0;">
      <span class="s-label">Visa Categories</span>
      <h2 class="s-heading">Choose your<br><em>travel purpose</em></h2>
    </div>

    <div class="svc-grid" style="margin-top: 0;">
      {p.visaTypes?.map((v) => (
        <div class="svc-cell">
          <div class="svc-icon">{v.icon}</div>
          <div class="svc-title">{v.title}</div>
          <p class="svc-desc">{v.desc}</p>
          <div style="margin-top: 1rem;">
            <span style="color: var(--gold);">Fee:</span> {v.fee}<br>
            <span style="color: var(--gold);">Processing:</span> {v.processing}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Requirements by Nationality -->
  <section style="background: var(--bg2);">
    <div class="s">
      <span class="s-label">Requirements by Country</span>
      <h2 class="s-heading">Who needs<br><em>a visa?</em></h2>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
        {p.requirementGroups?.map((g) => (
          <div style="background: var(--bg3); padding: 2rem; border-radius: 8px;">
            <h3 style="color: var(--gold); margin-bottom: 1rem;">{g.icon} {g.title}</h3>
            <p>{g.intro}</p>
            <ul style="margin-top: 1rem; list-style-position: inside;">
              {g.items.map((item) => <li>{item}</li>)}
            </ul>
            <p style="margin-top: 1rem;"><strong>{g.footnote}</strong></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="s">
    <div class="dest-intro" style="padding: 0 0 3rem 0;">
      <span class="s-label">How to Apply</span>
      <h2 class="s-heading">Simple<br><em>3-step process</em></h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
      {p.steps?.map((step) => (
        <div style="text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">{step.icon}</div>
          <h3 style="color: var(--gold); margin-bottom: 0.5rem;">{step.title}</h3>
          <p style="color: var(--ink2);">{step.desc}</p>
        </div>
      ))}
    </div>

    {p.notes && (
      <div class="info-box" style="background: var(--bg2); padding: 2rem; margin-top: 3rem; border-left: 3px solid var(--gold);">
        <h4 style="color: var(--gold); margin-bottom: 1rem;">📌 Important Notes</h4>
        <ul style="list-style-position: inside; color: var(--ink2);">
          {p.notes.map((note) => <li>{note}</li>)}
        </ul>
      </div>
    )}
  </section>

  <Footer />
</Layout>
