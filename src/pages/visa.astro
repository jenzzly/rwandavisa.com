---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Rwanda Visa Services - Easy E-Visa Application Guide">
  <Header />
  
  <!-- Hero -->
  <section id="visa-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">Visa Services</span>
        <h1 class="s-heading">Rwanda<br><em>E-Visa Guide 2025</em></h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">Step-by-step guidance for Rwanda's online visa system — approved in as little as 72 hours for most nationalities.</p>
      </div>
    </div>
  </section>

  <!-- Ad Top -->
  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Visa Types -->
  <section class="s">
    <div class="dest-intro" style="padding: 0 0 3rem 0;">
      <span class="s-label reveal">Visa Categories</span>
      <h2 class="s-heading reveal d1">Choose your<br><em>travel purpose</em></h2>
    </div>
    
    <div class="svc-grid" style="margin-top: 0;">
      <div class="svc-cell reveal">
        <div class="svc-icon">🏖️</div>
        <div class="svc-title">Tourist Visa</div>
        <p class="svc-desc">30-day single entry for leisure travel, sightseeing, and visiting family. Renewable once in-country.</p>
        <div style="margin-top: 1rem;">
          <span style="color: var(--gold);">Fee:</span> $50<br>
          <span style="color: var(--gold);">Processing:</span> 3-5 business days
        </div>
      </div>
      
      <div class="svc-cell reveal d1">
        <div class="svc-icon">💼</div>
        <div class="svc-title">Business Visa</div>
        <p class="svc-desc">For meetings, conferences, training, or short-term professional engagements. Valid for 30-90 days.</p>
        <div style="margin-top: 1rem;">
          <span style="color: var(--gold);">Fee:</span> $50<br>
          <span style="color: var(--gold);">Processing:</span> 3-5 business days
        </div>
      </div>
      
      <div class="svc-cell reveal d2">
        <div class="svc-icon">🎓</div>
        <div class="svc-title">Student Visa</div>
        <p class="svc-desc">For academic programs, research, or internships at Rwandan institutions. Valid for duration of study.</p>
        <div style="margin-top: 1rem;">
          <span style="color: var(--gold);">Fee:</span> $50<br>
          <span style="color: var(--gold);">Processing:</span> 7-10 business days
        </div>
      </div>
      
      <div class="svc-cell reveal d3">
        <div class="svc-icon">✈️</div>
        <div class="svc-title">Transit Visa</div>
        <p class="svc-desc">For passing through Rwanda to another destination. Valid for up to 72 hours.</p>
        <div style="margin-top: 1rem;">
          <span style="color: var(--gold);">Fee:</span> $30<br>
          <span style="color: var(--gold);">Processing:</span> 24-48 hours
        </div>
      </div>
    </div>
  </section>

  <!-- Requirements by Nationality -->
  <section style="background: var(--bg2);">
    <div class="s">
      <span class="s-label reveal">Requirements by Country</span>
      <h2 class="s-heading reveal d1">Who needs<br><em>a visa?</em></h2>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
        <div class="reveal" style="background: var(--bg3); padding: 2rem; border-radius: 8px;">
          <h3 style="color: var(--gold); margin-bottom: 1rem;">🌍 Visa-Free Access</h3>
          <p>All African Union member states, including:</p>
          <ul style="margin-top: 1rem; list-style-position: inside;">
            <li>Kenya, Uganda, Tanzania</li>
            <li>South Africa, Nigeria, Ghana</li>
            <li>Ethiopia, Senegal, Egypt</li>
          </ul>
          <p style="margin-top: 1rem;"><strong>Stay:</strong> Up to 90 days</p>
        </div>
        
        <div class="reveal d1" style="background: var(--bg3); padding: 2rem; border-radius: 8px;">
          <h3 style="color: var(--gold); margin-bottom: 1rem;">📋 E-Visa Required</h3>
          <p>Most other nationalities need an e-visa:</p>
          <ul style="margin-top: 1rem; list-style-position: inside;">
            <li>United States, Canada</li>
            <li>United Kingdom, Australia</li>
            <li>Germany, France, Italy</li>
            <li>China, India, Japan</li>
          </ul>
          <p style="margin-top: 1rem;"><strong>Processing:</strong> 72 hours average</p>
        </div>
        
        <div class="reveal d2" style="background: var(--bg3); padding: 2rem; border-radius: 8px;">
          <h3 style="color: var(--gold); margin-bottom: 1rem;">✅ Visa on Arrival</h3>
          <p>Available at Kigali Airport for:</p>
          <ul style="margin-top: 1rem; list-style-position: inside;">
            <li>All AU member states</li>
            <li>Select other nationalities</li>
          </ul>
          <p style="margin-top: 1rem;"><strong>Fee:</strong> $50 cash or card</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="s">
    <div class="dest-intro" style="padding: 0 0 3rem 0;">
      <span class="s-label reveal">How to Apply</span>
      <h2 class="s-heading reveal d1">Simple<br><em>3-step process</em></h2>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
      <div class="reveal" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">1️⃣</div>
        <h3 style="color: var(--gold); margin-bottom: 0.5rem;">Complete Online Form</h3>
        <p style="color: var(--ink2);">Fill out the application at irembo.gov.rw with your personal and travel details.</p>
      </div>
      
      <div class="reveal d1" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">2️⃣</div>
        <h3 style="color: var(--gold); margin-bottom: 0.5rem;">Upload Documents</h3>
        <p style="color: var(--ink2);">Passport scan, photo, flight booking, and accommodation proof.</p>
      </div>
      
      <div class="reveal d2" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">3️⃣</div>
        <h3 style="color: var(--gold); margin-bottom: 0.5rem;">Pay & Receive</h3>
        <p style="color: var(--ink2);">Pay $50 online and receive your approved visa via email within 72 hours.</p>
      </div>
    </div>
    
    <div class="info-box" style="background: var(--bg2); padding: 2rem; margin-top: 3rem; border-left: 3px solid var(--gold);">
      <h4 style="color: var(--gold); margin-bottom: 1rem;">📌 Important Notes</h4>
      <ul style="list-style-position: inside; color: var(--ink2);">
        <li>Passport must be valid for at least 6 months from arrival date</li>
        <li>Yellow fever vaccination certificate required for travelers from endemic countries</li>
        <li>Print your e-visa approval — you'll need it for boarding and arrival</li>
        <li>East Africa Tourist Visa allows travel between Rwanda, Kenya, and Uganda ($100)</li>
      </ul>
    </div>
  </section>

  <Footer />
</Layout>