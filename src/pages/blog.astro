---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Rwanda Travel Blog - Latest News & Tips">
  <Header />
  
  <section id="blog-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">Travel Blog</span>
        <h1 class="s-heading">Latest<br><em>Rwanda Insights</em></h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">News, travel tips, and inspiration for your Rwanda journey.</p>
      </div>
    </div>
  </section>

  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Blog Posts -->
  <section class="s">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem;">
      <!-- Post 1 -->
      <article class="reveal" style="background: var(--bg2); border-radius: 8px; overflow: hidden;">
        <img src="/images/rwanda_gorilla_nature_1763982585054.png" alt="Mountain gorilla" style="width: 100%; height: 220px; object-fit: cover;">
        <div style="padding: 1.5rem;">
          <div style="color: var(--gold); font-size: 0.7rem; text-transform: uppercase; margin-bottom: 0.5rem;">March 15, 2025</div>
          <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem;">Gorilla Trekking Permits Increase in 2025</h3>
          <p style="color: var(--ink2); line-height: 1.6;">Rwanda Development Board announces new pricing structure for gorilla permits. What travelers need to know before booking.</p>
          <a href="/blog/gorilla-permit-increase-2025" style="display: inline-block; margin-top: 1rem; color: var(--gold); text-decoration: none;">Read more →</a>
        </div>
      </article>
      
      <!-- Post 2 -->
      <article class="reveal d1" style="background: var(--bg2); border-radius: 8px; overflow: hidden;">
        <img src="/images/kigali_city_view_1763982611089.png" alt="Kigali city" style="width: 100%; height: 220px; object-fit: cover;">
        <div style="padding: 1.5rem;">
          <div style="color: var(--gold); font-size: 0.7rem; text-transform: uppercase; margin-bottom: 0.5rem;">March 10, 2025</div>
          <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem;">Kigali Named Africa's Safest City Again</h3>
          <p style="color: var(--ink2); line-height: 1.6;">Kigali maintains its position as Africa's safest capital according to 2025 Global Peace Index rankings.</p>
          <a href="/blog/kigali-safest-city-2025" style="display: inline-block; margin-top: 1rem; color: var(--gold); text-decoration: none;">Read more →</a>
        </div>
      </article>
      
      <!-- Post 3 -->
      <article class="reveal d2" style="background: var(--bg2); border-radius: 8px; overflow: hidden;">
        <img src="/images/rwanda_landscape_hero_1763982560164.png" alt="Lake Kivu" style="width: 100%; height: 220px; object-fit: cover;">
        <div style="padding: 1.5rem;">
          <div style="color: var(--gold); font-size: 0.7rem; text-transform: uppercase; margin-bottom: 0.5rem;">March 5, 2025</div>
          <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem;">New Direct Flights to Rwanda Announced</h3>
          <p style="color: var(--ink2); line-height: 1.6;">Major airlines add new routes to Kigali International Airport from Europe and Asia making Rwanda more accessible.</p>
          <a href="/blog/new-flights-to-rwanda" style="display: inline-block; margin-top: 1rem; color: var(--gold); text-decoration: none;">Read more →</a>
        </div>
      </article>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section style="background: var(--bg2);">
    <div class="s" style="text-align: center;">
      <h2 class="s-heading">Stay<br><em>Updated</em></h2>
      <p style="color: var(--ink2); margin-top: 1rem;">Subscribe to our newsletter for travel tips and exclusive offers.</p>
      <form id="newsletterForm" style="max-width: 400px; margin: 2rem auto 0; display: flex; gap: 1rem;">
        <input id="newsletterEmail" type="email" placeholder="Your email address" required style="flex: 1; padding: 0.8rem; background: var(--bg3); border: 1px solid var(--border); color: var(--ink); border-radius: 4px;">
        <button type="submit" style="padding: 0.8rem 1.5rem; background: var(--gold); color: var(--bg); border: none; border-radius: 4px; cursor: pointer;">Subscribe</button>
      </form>
    </div>
  </section>

  <Footer />
  <script>
    document.getElementById('newsletterForm')?.addEventListener('submit', event => {
      event.preventDefault();
      const email = (document.getElementById('newsletterEmail') as HTMLInputElement).value;
      window.location.href = `mailto:byja1101@gmail.com?subject=${encodeURIComponent('Rwanda Visa newsletter signup')}&body=${encodeURIComponent(`Please add ${email} to the newsletter.`)}`;
    });
  </script>
</Layout>
