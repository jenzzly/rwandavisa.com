---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'privacy');
const p = page!.data;

// Minimal markdown-to-HTML for this one field: ### headings and paragraphs.
function renderBody(md: string) {
  return md
    .trim()
    .split(/\n\s*\n/)
    .map((block) => {
      const trimmed = block.trim();
      if (trimmed.startsWith('### ')) {
        return `<h3>${trimmed.slice(4)}</h3>`;
      }
      return `<p>${trimmed}</p>`;
    })
    .join('\n');
}
---
<Layout title={p.title}>
  <Header />

  <div style="padding-top: 150px;" class="s">
    <div class="s-narrow" style="margin: 0 auto;">
      <h1 class="s-heading">Privacy<br><em>Policy</em></h1>
      <div class="privacy-body" style="margin-top: 2rem; color: var(--ink2); line-height: 1.8;" set:html={renderBody(p.body ?? '')} />
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .privacy-body :global(h3) {
    color: var(--gold);
    margin-top: 2rem;
  }
</style>
