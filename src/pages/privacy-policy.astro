---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy - RwandaVisa.com">
  <Header />
  
  <div style="padding-top: 150px;" class="s">
    <div class="s-narrow" style="margin: 0 auto;">
      <h1 class="s-heading">Privacy<br><em>Policy</em></h1>
      <div style="margin-top: 2rem; color: var(--ink2); line-height: 1.8;">
        <p>Last updated: July 2026</p>
        
        <h3 style="color: var(--gold); margin-top: 2rem;">Information We Collect</h3>
        <p>When you use our services, we may collect personal information including name, email address, phone number, passport details, travel preferences, and payment information.</p>
        
        <h3 style="color: var(--gold); margin-top: 2rem;">How We Use Your Information</h3>
        <p>We use your information to process visa applications, book tours, provide customer support, improve our services, and send travel updates. We never sell your personal data to third parties.</p>
        
        <h3 style="color: var(--gold); margin-top: 2rem;">Data Security</h3>
        <p>We implement industry-standard security measures to protect your information. Our systems are encrypted and access is restricted to authorized personnel only.</p>
        
        <h3 style="color: var(--gold); margin-top: 2rem;">Contact Us</h3>
        <p>For privacy-related inquiries, contact us at byja1101@gmail.com.</p>
      </div>
    </div>
  </div>
  
  <Footer />
</Layout>