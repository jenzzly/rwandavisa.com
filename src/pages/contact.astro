---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
const p = page!.data;

// This can be overridden in the deployment environment if the donation page changes.
const supportUrl = import.meta.env.PUBLIC_SUPPORT_URL || 'https://www.paypal.com/donate/?business=4GVQD57J4EWE8&no_recurring=0&item_name=I+hope+i+was+able+to+help+with+your+questions+about+traveling+to+Rwanda&currency_code=USD';
---

<Layout title={p.title} description="Support Rwanda Visa and request personal visa or travel assistance.">
  <Header />

  <section class="s support-hero">
    <div class="support-gate" id="supportGate">
      <img class="support-mark" src="/brand/rwanda-visa-mark.png" alt="Rwanda Visa logo" />
      <span class="s-label">{p.label}</span>
      <h1 class="s-heading">{p.heading}</h1>
      {p.intro?.map((line) => <p class="support-copy">{line}</p>)}

      <div class="support-options" aria-label="Suggested support amounts">
        {p.supportOptions?.map((opt) => (
          <div class="support-option"><strong>{opt.amount}</strong>{opt.label}</div>
        ))}
      </div>

      <a class="support-button" href={supportUrl} target="_blank" rel="noopener">Support Rwanda Visa ↗</a>
      <p class="support-note">After contributing, return here to send your request. Thank you for helping us keep Rwanda travel information accessible.</p>
      <button class="support-unlock" id="unlockContact" type="button">I’ve completed my donation — reveal support options</button>
    </div>
  </section>

  <section class="s contact-private" id="privateContact" aria-live="polite">
    <div class="private-contact-intro">
      <span class="s-label">Private contact</span>
      <h2 class="s-heading">Your support<br><em>options are open.</em></h2>
      <p class="s-body">Thank you for supporting RwandaVisa. Choose the quickest way to reach us, or send a detailed private request below.</p>
    </div>

    <div class="private-contact-options">
      {p.contactChannels?.map((ch) => (
        <a class="private-contact-card" href={ch.url} target="_blank" rel="noopener">
          <span class="private-contact-icon">{ch.icon}</span>
          <span><strong>{ch.title}</strong><small>{ch.detail}</small></span>
          <b>↗</b>
        </a>
      ))}
    </div>

    <div style="max-width: 800px; margin: 0 auto; background: var(--bg2); padding: 3rem; border-radius: 12px;">
      <form id="contactForm">
        <div style="margin-bottom: 1.5rem;">
          <label for="name" style="display: block; margin-bottom: 0.5rem; color: var(--gold);">Full Name *</label>
          <input id="name" type="text" name="name" required style="width: 100%; padding: 0.8rem; background: var(--bg3); border: 1px solid var(--border); color: var(--ink); border-radius: 4px;">
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label for="email" style="display: block; margin-bottom: 0.5rem; color: var(--gold);">Email Address *</label>
          <input id="email" type="email" name="email" required style="width: 100%; padding: 0.8rem; background: var(--bg3); border: 1px solid var(--border); color: var(--ink); border-radius: 4px;">
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label for="subject" style="display: block; margin-bottom: 0.5rem; color: var(--gold);">Subject *</label>
          <select id="subject" name="subject" required style="width: 100%; padding: 0.8rem; background: var(--bg3); border: 1px solid var(--border); color: var(--ink); border-radius: 4px;">
            <option value="">Select subject...</option>
            <option value="visa">Visa application assistance</option>
            <option value="tour">Tour booking inquiry</option>
            <option value="itinerary">Custom itinerary request</option>
            <option value="general">General travel question</option>
          </select>
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label for="message" style="display: block; margin-bottom: 0.5rem; color: var(--gold);">Message *</label>
          <textarea id="message" name="message" rows="6" required style="width: 100%; padding: 0.8rem; background: var(--bg3); border: 1px solid var(--border); color: var(--ink); border-radius: 4px;"></textarea>
        </div>
        <button type="submit" style="width: 100%; padding: 1rem; background: var(--gold); color: #fff; border: none; border-radius: 4px; font-weight: 600; cursor: pointer;">Open email request →</button>
      </form>
      <p style="text-align: center; color: var(--ink3); font-size: 0.8rem; margin-top: 1rem;">We usually respond within 24 hours, Monday–Friday.</p>
    </div>
  </section>

  <script>
    const gate = document.getElementById('supportGate');
    const privateContact = document.getElementById('privateContact');
    const unlock = () => {
      sessionStorage.setItem('rwandaVisaSupportGate', 'unlocked');
      gate?.closest('section')?.remove();
      privateContact?.classList.add('is-unlocked');
      document.getElementById('name')?.focus();
    };

    if (sessionStorage.getItem('rwandaVisaSupportGate') === 'unlocked') unlock();
    document.getElementById('unlockContact')?.addEventListener('click', unlock);

    document.getElementById('contactForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget as HTMLFormElement;
      const data = new FormData(form);
      const subject = `[Rwanda Visa request] ${data.get('subject')}`;
      const message = `Name: ${data.get('name')}\nEmail: ${data.get('email')}\n\n${data.get('message')}`;
      window.location.href = `mailto:byja1101@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;
    });
  </script>

  <Footer />
</Layout>
