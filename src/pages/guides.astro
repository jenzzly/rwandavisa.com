---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Rwanda Travel Guides - Expert Tips & Resources">
  <Header />
  
  <section id="guides-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">Travel Guides</span>
        <h1 class="s-heading">Expert<br><em>Rwanda Resources</em></h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">In-depth guides to help you plan your perfect Rwanda journey.</p>
      </div>
    </div>
  </section>

  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Guide Categories -->
  <section class="s">
    <div class="dest-list" style="padding: 0;">
      <!-- Visa Guide -->
      <div class="dest-row">
        <div class="dest-text-side" style="background: var(--bg3);">
          <div class="dest-num reveal">01</div>
          <div class="dest-tag-pill reveal d1">Essential Information</div>
          <h3 class="dest-name reveal d1">Complete Rwanda Visa Guide 2025</h3>
          <p class="dest-desc reveal d2">Everything you need to know about Rwanda's e-visa system — requirements, fees, processing times, and step-by-step application instructions for every nationality.</p>
          <div style="margin: 1rem 0;">
            <span style="color: var(--gold);">📅 Updated:</span> March 2025<br>
            <span style="color: var(--gold);">⏱️ Reading time:</span> 8 minutes
          </div>
          <a href="/guides/rwanda-visa-requirements" class="dest-link reveal d3">Read full guide →</a>
        </div>
        <div class="dest-img-side" style="background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 4rem;">🛂</div>
      </div>
      
      <!-- Gorilla Trekking Guide -->
      <div class="dest-row reverse">
        <div class="dest-text-side" style="background: var(--bg3);">
          <div class="dest-num reveal">02</div>
          <div class="dest-tag-pill reveal d1">Wildlife</div>
          <h3 class="dest-name reveal d1">Gorilla Trekking: Complete Guide</h3>
          <p class="dest-desc reveal d2">How to book permits, best times to visit, what to pack, physical preparation, and what to expect during your once-in-a-lifetime mountain gorilla encounter.</p>
          <div style="margin: 1rem 0;">
            <span style="color: var(--gold);">📅 Updated:</span> February 2025<br>
            <span style="color: var(--gold);">⏱️ Reading time:</span> 12 minutes
          </div>
          <a href="/guides/gorilla-trekking-rwanda" class="dest-link reveal d3">Read full guide →</a>
        </div>
        <div class="dest-img-side" style="background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 4rem;">🦍</div>
      </div>
      
      <!-- Best Time to Visit -->
      <div class="dest-row">
        <div class="dest-text-side" style="background: var(--bg3);">
          <div class="dest-num reveal">03</div>
          <div class="dest-tag-pill reveal d1">Planning</div>
          <h3 class="dest-name reveal d1">Best Time to Visit Rwanda</h3>
          <p class="dest-desc reveal d2">Month-by-month breakdown of Rwanda's weather, peak vs. low seasons, wildlife viewing opportunities, and when to avoid the rains for your specific activities.</p>
          <div style="margin: 1rem 0;">
            <span style="color: var(--gold);">📅 Updated:</span> January 2025<br>
            <span style="color: var(--gold);">⏱️ Reading time:</span> 6 minutes
          </div>
          <a href="/guides/best-time-visit-rwanda" class="dest-link reveal d3">Read full guide →</a>
        </div>
        <div class="dest-img-side" style="background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 4rem;">🌤️</div>
      </div>
      
      <!-- Expat Living -->
      <div class="dest-row reverse">
        <div class="dest-text-side" style="background: var(--bg3);">
          <div class="dest-num reveal">04</div>
          <div class="dest-tag-pill reveal d1">Living in Rwanda</div>
          <h3 class="dest-name reveal d1">Complete Expat Guide to Kigali</h3>
          <p class="dest-desc reveal d2">Housing, healthcare, international schools, cost of living, work permits, and everything you need to know about relocating to Rwanda's capital.</p>
          <div style="margin: 1rem 0;">
            <span style="color: var(--gold);">📅 Updated:</span> March 2025<br>
            <span style="color: var(--gold);">⏱️ Reading time:</span> 15 minutes
          </div>
          <a href="/guides/living-in-rwanda-expat" class="dest-link reveal d3">Read full guide →</a>
        </div>
        <div class="dest-img-side" style="background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 4rem;">🏠</div>
      </div>
    </div>
  </section>

  <!-- Quick Tips -->
  <section style="background: var(--bg2);">
    <div class="s">
      <span class="s-label reveal">Quick Tips</span>
      <h2 class="s-heading reveal d1">Before you go<br><em>know this</em></h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
        <div class="reveal" style="background: var(--bg3); padding: 1.5rem; border-left: 3px solid var(--gold);">
          <h4 style="color: var(--gold);">💰 Currency</h4>
          <p style="color: var(--ink2);">Rwandan Franc (RWF). ATMs available in Kigali. Cards accepted at hotels and upscale restaurants.</p>
        </div>
        <div class="reveal d1" style="background: var(--bg3); padding: 1.5rem; border-left: 3px solid var(--gold);">
          <h4 style="color: var(--gold);">🗣️ Language</h4>
          <p style="color: var(--ink2);">Kinyarwanda, English, French. English widely spoken in tourist areas.</p>
        </div>
        <div class="reveal d2" style="background: var(--bg3); padding: 1.5rem; border-left: 3px solid var(--gold);">
          <h4 style="color: var(--gold);">🔌 Electricity</h4>
          <p style="color: var(--ink2);">220-240V, Type C/E/F plugs. Bring a universal adapter.</p>
        </div>
        <div class="reveal d3" style="background: var(--bg3); padding: 1.5rem; border-left: 3px solid var(--gold);">
          <h4 style="color: var(--gold);">💉 Health</h4>
          <p style="color: var(--ink2);">Yellow fever vaccine required. Malaria prophylaxis recommended.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>