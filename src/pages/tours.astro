---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import OperatorGrid from '../components/OperatorGrid.astro';
import { getCollection, getEntry } from 'astro:content';

const page = await getEntry('pages', 'tours');
const p = page!.data;

const tours = (await getCollection('tours')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title={p.title}>
  <Header />

  <section id="tours-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">{p.label}</span>
        <h1 class="s-heading">{p.heading}</h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">{p.subheading}</p>
      </div>
    </div>
  </section>

  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <SponsorBanner placement="tours" />

  <!-- Tour Packages -->
  <section class="s">
    <div class="dest-list" style="padding: 0;">
      {tours.map((tour, i) => (
        <div class={`dest-row ${i % 2 === 1 ? 'reverse' : ''}`}>
          <div class="dest-img-side">
            <img src={tour.data.image} alt={tour.data.title} loading="lazy" />
          </div>
          <div class="dest-text-side">
            <div class="dest-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="dest-tag-pill">{tour.data.tagPill}</div>
            <h3 class="dest-name">{tour.data.title}</h3>
            <p class="dest-desc">{tour.data.description}</p>
            <div style="margin: 1rem 0; color: var(--gold);">
              <strong>Duration:</strong> {tour.data.duration} | <strong>{tour.data.price}</strong>
            </div>
            <a href="/contact" class="dest-link">Book this tour →</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Custom Tours CTA -->
  <section style="background: var(--bg2);">
    <div class="s" style="text-align: center;">
      <h2 class="s-heading">{p.ctaHeading}</h2>
      {p.intro?.map((line) => <p class="s-body" style="margin: 1.5rem auto;">{line}</p>)}
      <div style="margin-top: 2rem;">
        {p.ctaButtons?.map((btn) => (
          <a href={btn.link} class="btn-gold" style="display: inline-block; background: var(--gold); color: var(--bg); padding: 0.8rem 2rem; text-decoration: none;">{btn.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Local Operators -->
  <OperatorGrid />

  <Footer />
</Layout>
