---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import OperatorGrid from '../components/OperatorGrid.astro';
---

<Layout title="Rwanda Tours - Gorilla Trekking & Safari Experiences">
  <Header />
  
  <section id="tours-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">Tours & Experiences</span>
        <h1 class="s-heading">Extraordinary<br><em>Rwanda Adventures</em></h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">Curated experiences with trusted local guides — from gorilla trekking to cultural immersions.</p>
      </div>
    </div>
  </section>

  <div class="ad-row">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <SponsorBanner placement="tours" />

  <!-- Tour Packages -->
  <section class="s">
    <div class="dest-list" style="padding: 0;">
      <!-- Gorilla Trekking -->
      <div class="dest-row">
        <div class="dest-img-side reveal-left">
          <img src="/images/rwanda_gorilla_nature_1763982585054.png" alt="Gorilla trekking in Volcanoes National Park" loading="lazy">
        </div>
        <div class="dest-text-side">
          <div class="dest-num reveal">01</div>
          <div class="dest-tag-pill reveal d1">Most Popular</div>
          <h3 class="dest-name reveal d1">Gorilla Trekking Experience</h3>
          <p class="dest-desc reveal d2">3-day adventure to Volcanoes National Park. Includes park entry, permit, guide, and luxury lodge accommodation. Encounter mountain gorillas in their natural habitat — a life-changing wildlife experience.</p>
          <div style="margin: 1rem 0; color: var(--gold);">
            <strong>Duration:</strong> 3 days | <strong>From:</strong> $1,800 per person
          </div>
          <a href="/contact" class="dest-link reveal d3">Book this tour →</a>
        </div>
      </div>
      
      <!-- Akagera Safari -->
      <div class="dest-row reverse">
        <div class="dest-img-side reveal-right">
          <img src="/images/visa_application_desk_1763983510721.png" alt="Akagera National Park safari" loading="lazy">
        </div>
        <div class="dest-text-side">
          <div class="dest-num reveal">02</div>
          <div class="dest-tag-pill reveal d1">Big Five Safari</div>
          <h3 class="dest-name reveal d1">Akagera Wildlife Safari</h3>
          <p class="dest-desc reveal d2">2-day safari adventure in Rwanda's only savannah park. Game drives with experienced guides, boat safari on Lake Ihema, and comfortable lodge accommodation. Spot lions, elephants, giraffes, and hippos.</p>
          <div style="margin: 1rem 0; color: var(--gold);">
            <strong>Duration:</strong> 2 days | <strong>From:</strong> $550 per person
          </div>
          <a href="/contact" class="dest-link reveal d3">Book this tour →</a>
        </div>
      </div>
      
      <!-- Golden Monkey Trekking -->
      <div class="dest-row">
        <div class="dest-img-side reveal-left">
          <img src="/images/rwanda_landscape_hero_1763982560164.png" alt="Golden monkey trekking" loading="lazy">
        </div>
        <div class="dest-text-side">
          <div class="dest-num reveal">03</div>
          <div class="dest-tag-pill reveal d1">Unique Wildlife</div>
          <h3 class="dest-name reveal d1">Golden Monkey Trek</h3>
          <p class="dest-desc reveal d2">1-day trek to see endangered golden monkeys in Volcanoes National Park. A more accessible primate experience that complements your gorilla trek. Perfect for photography enthusiasts and nature lovers.</p>
          <div style="margin: 1rem 0; color: var(--gold);">
            <strong>Duration:</strong> 1 day | <strong>From:</strong> $150 per person
          </div>
          <a href="/contact" class="dest-link reveal d3">Book this tour →</a>
        </div>
      </div>
      
      <!-- Lake Kivu Escape -->
      <div class="dest-row reverse">
        <div class="dest-img-side reveal-right">
          <img src="/images/kigali_modern_life_1763983567881.png" alt="Lake Kivu boat cruise" loading="lazy">
        </div>
        <div class="dest-text-side">
          <div class="dest-num reveal">04</div>
          <div class="dest-tag-pill reveal d1">Relaxation</div>
          <h3 class="dest-name reveal d1">Lake Kivu Getaway</h3>
          <p class="dest-desc reveal d2">3-day lakeside retreat in Gisenyi. Includes boat cruise, kayaking, beach time, and visits to coffee plantations. Perfect post-safari relaxation with stunning sunsets over Africa's sixth-largest lake.</p>
          <div style="margin: 1rem 0; color: var(--gold);">
            <strong>Duration:</strong> 3 days | <strong>From:</strong> $420 per person
          </div>
          <a href="/contact" class="dest-link reveal d3">Book this tour →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Tours CTA -->
  <section style="background: var(--bg2);">
    <div class="s" style="text-align: center;">
      <h2 class="s-heading">Need a<br><em>Custom Itinerary?</em></h2>
      <p class="s-body" style="margin: 1.5rem auto;">Combine multiple experiences into your perfect Rwanda journey. Our travel designers will craft a personalized itinerary matching your budget and interests.</p>
      <div style="margin-top: 2rem;">
        <a href="/itinerary" class="btn-gold" style="display: inline-block; background: var(--gold); color: var(--bg); padding: 0.8rem 2rem; text-decoration: none;">Start Planning →</a>
      </div>
    </div>
  </section>

  <!-- Featured Local Operators -->
  <OperatorGrid />

  <Footer />
</Layout>