---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import OperatorGrid from '../components/OperatorGrid.astro';
---

<Layout title="Rwanda Tour Operators Directory - Rwanda Visa">
  <Header />

  <section id="operators-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">Directory</span>
        <h1 class="s-heading">Rwanda tour<br><em>operators</em></h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">Local, licensed operators for gorilla trekking, safaris, and custom itineraries.</p>
      </div>
    </div>
  </section>

  <OperatorGrid />

  <!-- Pitch for operators wanting a listing -->
  <section style="background: var(--bg2);">
    <div class="s" style="text-align: center;">
      <span class="s-label reveal">For Operators</span>
      <h2 class="s-heading reveal d1">Get listed<br><em>in front of travelers</em></h2>
      <p class="s-body" style="max-width: 650px; margin: 1.5rem auto 0;">
        We work with a limited number of Rwanda-based tour operators, listed directly on our guides, tours, and directory pages.
        Featured placements get top billing and a badge; standard listings still appear in the full directory.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/contact" class="btn-gold" style="display: inline-block; background: var(--gold); color: var(--bg); padding: 0.8rem 2rem; text-decoration: none;">Enquire about a listing →</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
