---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import OperatorGrid from '../components/OperatorGrid.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'operators');
const p = page!.data;
---

<Layout title={p.title}>
  <Header />

  <section id="operators-hero" style="padding-top: 150px; background: var(--bg2);">
    <div class="s">
      <div class="s-narrow" style="margin: 0 auto; text-align: center;">
        <span class="s-label">{p.label}</span>
        <h1 class="s-heading">{p.heading}</h1>
        <p class="s-body" style="max-width: 700px; margin: 1.5rem auto 0;">{p.subheading}</p>
      </div>
    </div>
  </section>

  <OperatorGrid />

  <!-- Pitch for operators wanting a listing -->
  <section style="background: var(--bg2);">
    <div class="s" style="text-align: center;">
      <span class="s-label reveal">{p.ctaLabel}</span>
      <h2 class="s-heading reveal d1">{p.ctaHeading}</h2>
      {p.intro?.map((line) => (
        <p class="s-body" style="max-width: 650px; margin: 1.5rem auto 0;">{line}</p>
      ))}
      <div style="margin-top: 2rem;">
        {p.ctaButtons?.map((btn) => (
          <a href={btn.link} class="btn-gold" style="display: inline-block; background: var(--gold); color: var(--bg); padding: 0.8rem 2rem; text-decoration: none;">{btn.label}</a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
