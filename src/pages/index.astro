---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SponsorBanner from '../components/SponsorBanner.astro';
import { getCollection, getEntry } from 'astro:content';

const page = await getEntry('pages', 'home');
const p = page!.data;

const routeStops = (await getCollection('destinations'))
  .filter((d) => d.data.onRoute)
  .sort((a, b) => a.data.order - b.data.order);

const guides = (await getCollection('guides')).slice(0, 3);

// Map waypoints: the route out, plus a return leg back to the first stop (Kigali).
const mapWaypoints = [
  ...routeStops.map((d) => ({
    name: d.data.name,
    slug: d.slug,
    coords: [d.data.lat, d.data.lng],
    desc: d.data.intro.split('.')[0] + '.',
    tag: d.data.tag ?? '',
  })),
  routeStops[0] && {
    name: routeStops[0].data.name,
    slug: routeStops[0].slug,
    coords: [routeStops[0].data.lat, routeStops[0].data.lng],
    desc: 'Return, farewell dinner',
    tag: 'RETURN',
  },
].filter(Boolean);
---

<Layout title="RwandaVisa — Your Trusted Rwanda Travel Partner">
  <Header />

  <!-- Hero with Interactive Route Map -->
  <section id="hero" style="position: relative; height: 100vh; min-height: 640px; width: 100%;">
    <div id="rwandaMap" style="height: 100%; width: 100%; position: absolute; top: 0; left: 0; z-index: 1;"></div>
    <div class="hero-grain"></div>
    <div class="hero-vignette"></div>
    <div class="hero-bottom-fade"></div>
    <div class="hero-content" style="position: relative; z-index: 3;">
      <p class="hero-eyebrow"><strong>{p.heroLabel}</strong></p>
      <h1 class="hero-title">{p.heroTitle}</h1>
      <p class="hero-sub">{p.heroSub}</p>
    </div>
    <div class="hero-scroll" onclick="document.getElementById('destinations')?.scrollIntoView({behavior:'smooth'})">
      <div class="scroll-line"></div>
      <span><strong>SCROLL TO EXPLORE</strong></span>
    </div>
  </section>

  <div class="ad-container">
    <div class="ad-label">Advertisement</div>
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="1234567890" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <SponsorBanner placement="homepage" />

  <section id="intro" style="padding:6rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start">
    <div class="intro-left reveal">
      <span class="s-label" style="background:rgba(0,158,96,0.1); padding:0.3rem 0.8rem; border-radius:40px; font-weight:bold;">{p.introLabel}</span>
      <h2 class="s-heading" style="margin-top:1.5rem;">{p.introHeading}</h2>
    </div>
    <div class="intro-right reveal d2">
      {p.intro?.map((line) => <p style="margin-top:1.2rem">{line}</p>)}
    </div>
  </section>

  <!-- Destinations Section with Route Stops -->
  <section id="destinations">
    <div class="dest-intro">
      <span class="s-label reveal"><strong>THE ROUTE DEEP DIVE</strong></span>
      <h2 class="s-heading reveal d1">Seven days,<br><strong><em>six unforgettable stops</em></strong></h2>
      <p class="s-body reveal d2"><strong>{routeStops.map((d) => d.data.name).join(' → ')} → {routeStops[0]?.data.name}</strong><br>Click any car marker on the map to explore each destination along this classic Rwanda circuit.</p>
    </div>

    <div class="dest-list">
      {routeStops.map((d, i) => (
        <div class={`dest-row ${i % 2 === 1 ? 'reverse' : ''}`}>
          <div class="dest-img-side">
            <img src={d.data.heroImage} alt={d.data.name} loading="lazy" />
          </div>
          <div class="dest-text-side">
            <div class="dest-num"><strong style="color:var(--gold);">{d.data.tag}</strong></div>
            <div class="dest-tag-pill"><strong>{d.data.label.toUpperCase()}</strong></div>
            <h3 class="dest-name"><strong>{d.data.name}</strong></h3>
            <p class="dest-desc">{d.data.intro}</p>
            <a href={`/destinations/${d.slug}`} class="dest-link"><strong>EXPLORE {d.data.name.split(' ')[0].toUpperCase()}</strong></a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Stats Section -->
  <section id="stats">
    <div class="stats-grid">
      {p.stats?.map((stat) => (
        <div class="stat-cell reveal">
          <div class="stat-num"><strong>{stat.number}</strong>{stat.suffix && <span style="font-size:.4em">{stat.suffix}</span>}</div>
          <div class="stat-label"><strong>{stat.label}</strong></div>
        </div>
      ))}
    </div>
  </section>

  <!-- Services Section -->
  <section id="services">
    <span class="s-label reveal"><strong>{p.servicesLabel}</strong></span>
    <h2 class="s-heading reveal d1">{p.servicesHeading}</h2>
    <div class="svc-grid">
      {p.services?.map((svc) => (
        <a href={svc.link} class="svc-cell reveal">
          <div class="svc-icon">{svc.icon}</div>
          <div class="svc-title"><strong>{svc.title}</strong></div>
          <p class="svc-desc">{svc.desc}</p>
          <span class="svc-arrow"><strong>{svc.linkText}</strong></span>
        </a>
      ))}
    </div>
  </section>

  <div class="ad-container">
    <div class="ad-label">Advertisement</div>
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8770614237621568"
      data-ad-slot="1234567893" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Editorial Section: latest guides, always fresh from the guides collection -->
  {guides.length > 0 && (
    <section id="editorial">
      <span class="s-label reveal"><strong>TRAVEL INTELLIGENCE</strong></span>
      <h2 class="s-heading reveal d1">Trusted by travelers<br><strong><em>who return</em></strong></h2>
      <div class="articles-list">
        {guides.map((g) => (
          <a href={`/guides/${g.slug}`} class="article-mini reveal">
            <span class="art-cat"><strong>{g.data.label.toUpperCase()}</strong></span>
            <h4><strong>{g.data.title}</strong></h4>
            <p>{g.data.intro}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Testimonial -->
  <div style="background: var(--bg-off); padding: 4rem 2rem; text-align: center;">
    <div style="max-width: 700px; margin: 0 auto;">
      <div style="font-family: var(--serif); font-size: 1.3rem; color: var(--ink-light); font-style: italic;">"{p.testimonialQuote}"</div>
      <div style="margin-top: 1rem; font-size: 0.8rem; color: var(--gold); font-weight: bold;">{p.testimonialAuthor}</div>
    </div>
  </div>

  <!-- CTA Section -->
  <section id="cta">
    <div class="cta-content">
      <span class="s-label" style="color:rgba(255,255,255,0.8);"><strong>{p.ctaLabel}</strong></span>
      <h2 class="cta-heading">{p.ctaHeading}</h2>
      <div class="cta-row">
        {p.ctaButtons?.map((btn, i) => (
          <a href={btn.link} class={i === 0 ? 'btn-gold' : 'btn-outline-gold'}><strong>{btn.label}</strong></a>
        ))}
      </div>
    </div>
  </section>

  <Footer />

  <!-- Load Leaflet and Routing Machine, then draw the route from destinations data -->
  <script type="application/json" id="route-data" set:html={JSON.stringify(mapWaypoints)} />
  <script>
    function loadScript(src, callback) {
      const script = document.createElement('script');
      script.src = src;
      script.onload = callback;
      script.onerror = () => console.error(`Failed to load script: ${src}`);
      document.head.appendChild(script);
    }

    const leafletCSS = document.createElement('link');
    leafletCSS.rel = 'stylesheet';
    leafletCSS.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(leafletCSS);

    const routingCSS = document.createElement('link');
    routingCSS.rel = 'stylesheet';
    routingCSS.href = 'https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css';
    document.head.appendChild(routingCSS);

    loadScript('https://unpkg.com/leaflet@1.9.4/dist/leaflet.js', () => {
      loadScript('https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js', () => {
        initMap();
      });
    });

    function initMap() {
      if (typeof L === 'undefined') {
        console.error('Leaflet (L) is not defined');
        return;
      }

      const routeWaypoints = JSON.parse(document.getElementById('route-data').textContent);

      const map = L.map('rwandaMap').setView([-1.9441, 29.8739], 7.5);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> & CartoDB',
        subdomains: 'abcd',
        maxZoom: 13,
        minZoom: 7
      }).addTo(map);

      const carIcon = L.divIcon({
        className: 'custom-car-marker',
        html: `<div style="background: #1e1e1e; width: 32px; height: 32px; border-radius: 8px 8px 4px 4px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.2); border-bottom: 2px solid #c9a96e;">
                 <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                   <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z" fill="#c9a96e"/>
                 </svg>
               </div>`,
        iconSize: [32, 32],
        popupAnchor: [0, -16]
      });

      routeWaypoints.forEach((wp) => {
        const marker = L.marker(wp.coords, { icon: carIcon }).addTo(map);
        marker.bindPopup(`
          <div style="font-family: 'Inter', sans-serif; padding: 8px; min-width: 200px;">
            <div style="margin-bottom: 8px;">
              <span style="background: #009E60; color: white; font-size: 10px; padding: 2px 8px; border-radius: 20px; display: inline-block; font-weight: bold;">${wp.tag}</span>
            </div>
            <strong style="color: #c9a96e; font-size: 16px; display: block; margin-bottom: 5px;">🚗 ${wp.name}</strong>
            <p style="margin: 5px 0; font-size: 11px; color: #4a4a4a;">${wp.desc}</p>
            <hr style="margin: 8px 0; border-color: #eee;">
            <a href="/destinations/${wp.slug}" style="color: #009E60; text-decoration: none; font-size: 11px; font-weight: bold;">EXPLORE →</a>
          </div>
        `);
      });

      const waypointsLatLng = routeWaypoints.map((wp) => L.latLng(wp.coords[0], wp.coords[1]));

      try {
        L.Routing.control({
          waypoints: waypointsLatLng,
          routeWhileDragging: false,
          show: false,
          lineOptions: {
            styles: [{ color: '#c9a96e', weight: 4, opacity: 0.85, dashArray: '8, 8' }],
            extendToWaypoints: true,
            missingRouteTolerance: 0
          },
          addWaypoints: false,
          draggableWaypoints: false,
          fitSelectedRoutes: false,
          showAlternatives: false,
          createMarker: function() { return null; }
        }).addTo(map);

        setTimeout(() => {
          const container = document.querySelector('.leaflet-routing-container');
          if (container) container.style.display = 'none';
        }, 500);
      } catch (err) {
        console.warn('Routing machine error:', err);
        const latlngs = routeWaypoints.map((wp) => wp.coords);
        L.polyline(latlngs, { color: '#c9a96e', weight: 4, dashArray: '8, 8' }).addTo(map);
      }

      const bounds = L.latLngBounds(routeWaypoints.map((wp) => wp.coords));
      map.fitBounds(bounds.pad(0.15));

      window.rwandaMap = map;
    }
  </script>

  <style>
    #rwandaMap {
      background: #e8e4d8;
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
    }
    .leaflet-popup-content-wrapper {
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .leaflet-popup-tip {
      background: white;
    }
    .leaflet-routing-container {
      display: none !important;
    }
    .ad-container {
      margin: 2rem auto;
      text-align: center;
      background: #faf8f2;
      border-radius: 16px;
      padding: 1rem;
      border: 1px solid var(--border);
      max-width: 1200px;
    }
    .ad-label {
      font-size: 0.65rem;
      text-transform: uppercase;
      color: #8b8b7a;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }
    @media (max-width: 768px) {
      .ad-container {
        margin: 1rem;
        padding: 0.8rem;
      }
    }
  </style>
</Layout>
