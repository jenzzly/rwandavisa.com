      }
    };
    
    // Wait for DOM to be ready before adding event listener
    document.addEventListener('DOMContentLoaded', () => {
      const generateBtn = document.getElementById('generateItineraryBtn');
      if (generateBtn) {
        generateBtn.addEventListener('click', () => {
          const purpose = document.getElementById('purposeSelect').value;
          const style = document.getElementById('styleSelect').value;
          const days = document.getElementById('daysCount').value;
          
          let itinerary = itineraries[purpose]?.[style] || itineraries.leisure.midrange;
          itinerary = itinerary.replace(/Day (\d+)/g, '<strong style="color: #c9a96e;">Day $1</strong>');
          itinerary = itinerary.replace(/\n/g, '<br>');
          
          const itineraryText = document.getElementById('itineraryText');
          const aiResult = document.getElementById('aiResult');
          if (itineraryText && aiResult) {
            itineraryText.innerHTML = itinerary;
            aiResult.style.display = 'block';
          }
        });
      }
