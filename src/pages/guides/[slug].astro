---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getLastEditedDate } from '../../utils/lastModified';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'guides'> };
const { Content } = await entry.render();
const updated = getLastEditedDate('guides', entry.slug, entry.data.date);
---
<Layout title={`${entry.data.title} - Rwanda Visa`}>
  <Header />
  <article class="s support-hero">
    <div class="s-narrow">
      <span class="s-label">{entry.data.label}</span>
      <h1 class="s-heading">{entry.data.title}</h1>
      <p class="s-body">{entry.data.intro}</p>
      {updated && <p class="guide-updated">Last updated {updated}</p>}
      <div class="s-body guide-body" style="max-width: 100%; margin-top: 1.5rem;">
        <Content />
      </div>
      <a class="support-button" href="/contact">Get personal help →</a>
    </div>
  </article>
  <Footer />
</Layout>

<style>
  .guide-updated {
    font-size: 0.8rem;
    color: var(--ink2);
    margin-top: 0.5rem;
  }
  .guide-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--gold);
    font-size: 1.3rem;
  }
  .guide-body :global(ul) {
    margin: 1rem 0;
    padding-left: 1.4rem;
  }
  .guide-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .guide-body :global(p) {
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .guide-body :global(.info-box) {
    margin-top: 2rem;
  }
</style>
