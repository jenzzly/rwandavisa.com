---
const year = new Date().getFullYear();
---
<footer>
  <div class="footer-top">
    <div class="footer-brand">
      <a class="footer-logo footer-logo-link" href="/" aria-label="Rwanda Visa home">
        <img src="/brand/rwanda-visa-mark.png" alt="Rwanda Visa logo" />
        <span>RwandaVisa</span>
      </a>
      <p>Your independent travel resource for Rwanda. Expert visa guidance, destination guides, and curated travel experiences. Not affiliated with the Government of Rwanda.</p>
    </div>
    <div class="footer-col">
      <h4>Destinations</h4>
      <a href="/destinations/kigali">Kigali</a>
      <a href="/destinations/musanze">Musanze</a>
      <a href="/destinations/gisenyi">Gisenyi</a>
      <a href="/destinations/huye">Huye</a>
      <a href="/destinations/karongi">Karongi</a>
      <a href="/destinations/akagera">Akagera</a>
    </div>
    <div class="footer-col">
      <h4>Services</h4>
      <a href="/visa">Visa Services</a>
      <a href="/itinerary">AI Itinerary</a>
      <a href="/tours">Tours</a>
      <a href="/guides">Travel Guides</a>
      <a href="/videos">Videos</a>
      <a href="/operators">Tour Operators</a>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <a href="/contact">Support &amp; get in touch</a>
      <a href="/contact">Visa assistance</a>
      <a href="/contact">Travel questions</a>
      <a href="/privacy-policy">Privacy Policy</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {year} RwandaVisa.com — Independent travel resource</span>
    <span>Kigali, Rwanda</span>
    <button type="button" onclick="window.showCookiePreferences && window.showCookiePreferences()" style="background:none;border:none;color:inherit;text-decoration:underline;cursor:pointer;font-size:inherit;padding:0;">Cookie preferences</button>
  </div>
</footer>

<form class="donate-float" action="https://www.paypal.com/donate" method="post" target="_blank">
  <input type="hidden" name="business" value="4GVQD57J4EWE8" />
  <input type="hidden" name="no_recurring" value="0" />
  <input type="hidden" name="item_name" value="RwandaVisa.com" />
  <input type="hidden" name="currency_code" value="USD" />
  <button class="donate-float-button" type="submit" title="Donate to RwandaVisa.com with PayPal">
    <span class="donate-float-icon" aria-hidden="true">♡</span>
    <span><strong>Support RwandaVisa</strong><small>Donate with PayPal</small></span>
    <span class="donate-float-arrow" aria-hidden="true">↗</span>
  </button>
</form>

<a class="visa-float" href="https://www.irembo.gov.rw/" target="_blank" rel="noopener" title="Apply for a Rwanda visa on the official IremboGov website">
  <span class="visa-float-icon" aria-hidden="true">🛂</span>
  <span><strong>Apply for a visa</strong><small>Official IremboGov site</small></span>
  <span class="donate-float-arrow" aria-hidden="true">↗</span>
</a>
